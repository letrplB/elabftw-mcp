{
  "name": "elabftw-mcp",
  "private": true,
  "description": "Monorepo for the elabftw MCP toolkit (@sura_ai/elabftw) and its hosted-mode HTTP server (@sura_ai/elabftw-hosted).",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "build:toolkit": "npm run build -w @sura_ai/elabftw",
    "build:hosted": "npm run build -w @sura_ai/elabftw-hosted",
    "dev:hosted": "npm run build:toolkit && node packages/hosted/dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/letrplB/elabftw-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/letrplB/elabftw-mcp/issues"
  },
  "homepage": "https://github.com/letrplB/elabftw-mcp#readme",
  "author": "bstn",
  "license": "MIT"
}
