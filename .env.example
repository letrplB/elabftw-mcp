# Hosted-mode deployment env vars. Copy to `.env` and fill in.
# Used by docker-compose.yml. See README → Hosted mode for the full matrix.

# --- Required ---

# Default eLabFTW base URL prefilled into the registration form.
# Users can edit it per-registration; this is just the default value.
ELABFTW_BASE_URL=https://elab.example.com

# Bare hostname Caddy auto-provisions a Let's Encrypt cert for.
# DNS A/AAAA record for this name must point at this host.
MCP_DOMAIN=mcp.example.tum.de

# --- Strongly recommended ---

# Public origin used in the personal MCP URL the registration page returns.
# Should be the https origin matching MCP_DOMAIN. Without this, the server
# falls back to the bind address, the registration page returns
# http://0.0.0.0:8000/... URLs, and DNS-rebind protection logs a warning.
MCP_PUBLIC_URL=https://mcp.example.tum.de

# --- Optional ---

# Override the auto-derived DNS-rebind allow-list. Comma-separated.
# Default: derived from MCP_PUBLIC_URL. Set this only if you need to
# accept additional Origin/Host header values.
# MCP_ALLOWED_HOSTS=mcp.example.tum.de,mcp.staging.example.tum.de
# MCP_ALLOWED_ORIGINS=https://mcp.example.tum.de,https://app.example.tum.de
